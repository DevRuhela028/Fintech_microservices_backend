# Kafka Configuration
KAFKA_BROKERS=localhost:29092

# User Service Database
USER_DB_HOST=localhost
USER_DB_PORT=5433
USER_DB_NAME=userdb
USER_DB_USER=postgres
USER_DB_PASSWORD=postgres

# Payment Service Database
PAYMENT_DB_HOST=localhost
PAYMENT_DB_PORT=5434
PAYMENT_DB_NAME=paymentdb
PAYMENT_DB_USER=postgres
PAYMENT_DB_PASSWORD=postgres

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=super_secret_jwt_key_example_change_me_in_prod
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Internal Service URLs
USER_SERVICE_URL=http://user-service:3000
PAYMENT_SERVICE_URL=http://payment-service:3001

# SMTP Configuration (Notification Service)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=smtp_password_example

# Security
X_INTERNAL_SECRET=secret_token_for_internal_service_communication

# Environment
NODE_ENV=development
SERVICE_NAME=unknown-service
